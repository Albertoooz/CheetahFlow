# === CheetahFlow Backend ===
CHEETAHFLOW_DATABASE_URL=sqlite+aiosqlite:///./cheetahflow.db
CHEETAHFLOW_ADMIN_TOKEN=changeme-admin-token-replace-in-production

# === OpenRouter (Phase B) ===
# OPENROUTER_API_KEY=sk-or-...

# === Langfuse Observability (optional) ===
# Get keys from Langfuse UI after first login (self-hosted) or https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=http://localhost:3100
# LANGFUSE_DEBUG=false

# === PostgreSQL (if using docker-compose) ===
POSTGRES_USER=cheetahflow
POSTGRES_PASSWORD=cheetahflow
POSTGRES_DB=cheetahflow
# When using Postgres instead of SQLite:
# CHEETAHFLOW_DATABASE_URL=postgresql+asyncpg://cheetahflow:cheetahflow@localhost:5432/cheetahflow

# === Frontend ===
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ADMIN_TOKEN=changeme-admin-token-replace-in-production
