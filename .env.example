# === AgentFlow Backend ===
AGENTFLOW_DATABASE_URL=sqlite+aiosqlite:///./agentflow.db
AGENTFLOW_ADMIN_TOKEN=changeme-admin-token-replace-in-production

# === OpenRouter (Phase B) ===
# OPENROUTER_API_KEY=sk-or-...

# === Langfuse Observability (optional) ===
# Get keys from Langfuse UI after first login (self-hosted) or https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=http://localhost:3100
# Set to "true" to enable debug logging for Langfuse SDK
# LANGFUSE_DEBUG=false

# === PostgreSQL (if using docker-compose) ===
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=agentflow
POSTGRES_DB=agentflow
# When using Postgres instead of SQLite:
# AGENTFLOW_DATABASE_URL=postgresql+asyncpg://agentflow:agentflow@localhost:5432/agentflow

# === Frontend ===
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
